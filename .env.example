ADAPTIVE_RAG_ENV=local
ADAPTIVE_RAG_LOG_LEVEL=INFO
ADAPTIVE_RAG_DATABASE_URL=postgresql+psycopg://adaptive_rag:adaptive_rag@localhost:5432/adaptive_rag
ADAPTIVE_RAG_VECTOR_STORE=pgvector
ADAPTIVE_RAG_GRAPH_STORE=disabled
ADAPTIVE_RAG_PROVIDER_RUNTIME_MODE=fake
# Local default: leave ADAPTIVE_RAG_PROVIDER_SECRETS_KEY empty and keep the
# generated Fernet key in this ignored file. Production should manage the key
# through ADAPTIVE_RAG_PROVIDER_SECRETS_KEY instead.
ADAPTIVE_RAG_PROVIDER_SECRETS_KEY=
ADAPTIVE_RAG_PROVIDER_SECRETS_KEY_FILE=.adaptive-rag/provider-secrets.key
ADAPTIVE_RAG_EMBEDDING_PROVIDER=fake
ADAPTIVE_RAG_EMBEDDING_MODEL=fake-embedding-v1
ADAPTIVE_RAG_SPARSE_EMBEDDING_PROVIDER=fake
ADAPTIVE_RAG_SPARSE_EMBEDDING_MODEL=fake-sparse-embedding-v1
ADAPTIVE_RAG_CHAT_PROVIDER=fake
ADAPTIVE_RAG_CHAT_MODEL=retrieval-grounded-local-v1
ADAPTIVE_RAG_RERANK_PROVIDER=fake
ADAPTIVE_RAG_RERANK_MODEL=fake-rerank-v1
ADAPTIVE_RAG_PROVIDER_MAX_COST_USD=
# Set only when running `docker compose --profile worker up worker`.
ADAPTIVE_RAG_WORKER_PROJECT_ID=
# Optional hosted provider smoke; not required for the default release gate.
ADAPTIVE_RAG_QWEN_API_KEY=
ADAPTIVE_RAG_QWEN_BASE_URL=
ADAPTIVE_RAG_NEO4J_URI=
ADAPTIVE_RAG_NEO4J_USERNAME=
ADAPTIVE_RAG_NEO4J_PASSWORD=
